    "Brain_MRI": {
      "type": "ImagingStudy",
      "reason": "Stroke",
      "procedure_code": {
        "system": "SNOMED-CT",
        "code": "113091000",
        "display": "Magnetic resonance imaging (procedure)"
      },
      "series": [
        {
          "body_site": {
            "system": "SNOMED-CT",
            "code": "12738006",
            "display": "Brain structure (body structure)"
          },
          "modality": {
            "system": "DICOM-DCM",
            "code": "MR",
            "display": "Magnetic Resonance"
          },
          "instances": [
            {
              "title": "MRI of the brain with diffusion-weighted imaging",
