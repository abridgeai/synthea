    "Pain_Symptom_Ends": {
      "type": "Symptom",
      "symptom": "Abdominal Pain",
      "cause": "Bowel Obstruction",
      "exact": {
        "quantity": 0
      },
      "direct_transition": "Distension_Symptom_Ends"
    },
    "Distension_Symptom_Ends": {
      "type": "Symptom",
      "symptom": "Abdominal Distension",
      "cause": "Bowel Obstruction",
      "exact": {
        "quantity": 0
      },
      "direct_transition": "Vomiting_Symptom_Ends"
    },
    "Vomiting_Symptom_Ends": {
      "type": "Symptom",
      "symptom": "Nausea/Vomiting",
      "cause": "Bowel Obstruction",
      "exact": {
        "quantity": 0
      },
      "direct_transition": "Obstipation_Symptom_Ends"
    },
    "Obstipation_Symptom_Ends": {
      "type": "Symptom",
      "symptom": "Constipation",
      "cause": "Bowel Obstruction",
      "exact": {
        "quantity": 0
      },
      "direct_transition": "SBO_Condition_End"
    },
    "SBO_Condition_End": {
      "type": "ConditionEnd",
      "condition_onset": "SBO_Onset",
      "direct_transition": "Wait_For_Recurrence"
