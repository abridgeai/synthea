      "range": {
        "low": 1,
        "high": 5,
        "unit": "years"
      },
      "remarks": [
        "Adhesive obstruction recurs. New episodes stop after age 85."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">",
            "quantity": 85,
            "unit": "years"
          },
          "transition": "Terminal"
        },
        {
          "distributions": [
            {
              "distribution": 0.25,
              "transition": "SBO_Onset"
            },
            {
              "distribution": 0.75,
              "transition": "Wait_For_Recurrence"
            }
          ]
        }
      ]
    },
    "Terminal": {
      "type": "Terminal"
    }
  },
  "gmf_version": 1
}
