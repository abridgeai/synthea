      "reason": "Cellulitis_Onset",
      "codes": [
        {
          "system": "RxNorm",
          "code": "1649987",
          "display": "doxycycline hyclate 100 MG"
        }
      ],
      "direct_transition": "End_Cellulitis_Encounter"
    },
    "End_Cellulitis_Encounter": {
