      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Active Allergy",
            "codes": [
              {
                "system": "RxNorm",
                "code": "7984",
                "display": "Penicillin V"
              }
            ]
          },
          "transition": "Prescribe_Doxycycline"
        },
        {
          "transition": "Prescribe_Cephalexin"
        }
      ]
    },
    "Prescribe_Cephalexin": {
      "type": "MedicationOrder",
      "assign_to_attribute": "cellulitis_antibiotic",
      "reason": "Cellulitis_Onset",
      "codes": [
        {
          "system": "RxNorm",
          "code": "197454",
          "display": "cephalexin 500 MG Oral Tablet"
        }
      ],
      "direct_transition": "End_Cellulitis_Encounter"
    },
    "Prescribe_Doxycycline": {
      "type": "MedicationOrder",
