        }
      ]
    },
    "Inpatient_Recovery": {
      "type": "MedicationEnd",
      "medication_order": "IV_Antibiotic",
      "direct_transition": "Hospital_Discharge"
    },
    "Hospital_Discharge": {
      "type": "EncounterEnd",
      "direct_transition": "Convalescence"
    },
    "Convalescence": {
      "type": "Delay",
