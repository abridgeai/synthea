{
  "name": "Parkinson's Disease",
  "remarks": [
    "This module models idiopathic Parkinson's disease. Onset is almost entirely after age 60. ",
    "Prevalence is roughly 1% of adults over 60, and the disease is about 1.5x more common in ",
    "men than women. This model sends 1.5% of men and 1.0% of women toward onset at a uniformly ",
    "distributed age between 60 and 85 (not all live long enough to reach onset, keeping the ",
    "prevalence among 60+ near the target).",
    "Sources: ",
    "Pringsheim T, et al. 'The prevalence of Parkinson's disease: a systematic review and ",
    "meta-analysis.' Mov Disord. 2014;29(13):1583-1590. ",
    "Van Den Eeden SK, et al. 'Incidence of Parkinson's disease: variation by age, gender, and ",
    "race/ethnicity.' Am J Epidemiol. 2003;157(11):1015-1022. (male:female rate ratio ~1.9, ",
    "onset rare before age 50, incidence peaks in the 70s).",
    "Clinical flow: tremor/bradykinesia/rigidity symptoms lead to a neurology ambulatory ",
    "encounter and diagnosis, treated with carbidopa/levodopa and 6-month neurology follow-ups. ",
    "The disease progresses over years (worsening symptoms and a dose increase at mid-stage), ",
    "and at the advanced stage patients develop fall risk and receive an assistance care plan. ",
    "A ~10% per-followup medication discontinuation branch models non-adherence, with ",
    "resumption at the next follow-up. Parkinson's shortens life expectancy: a conservative 3% ",
    "death probability per 6-month cycle applies at the advanced stage only. This module does ",
    "NOT onset dementia (dementia.json models dementia); it sets the boolean attribute ",
    "'parkinsons' so other modules can correlate with this condition."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "remarks": [
        "======================================================================",
        " INCIDENCE: ~1% of 60+; ~1.5x more common in men                      ",
        "======================================================================"
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "M"
          },
          "distributions": [
            {
              "distribution": 0.015,
              "transition": "Delay_Until_PD_Onset"
            },
            {
              "distribution": 0.985,
              "transition": "Terminal"
            }
          ]
        },
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "F"
          },
          "distributions": [
            {
              "distribution": 0.01,
              "transition": "Delay_Until_PD_Onset"
            },
            {
              "distribution": 0.99,
              "transition": "Terminal"
            }
          ]
        }
      ]
    },
    "Delay_Until_PD_Onset": {
      "type": "Delay",
      "range": {
        "low": 60,
        "high": 85,
        "unit": "years"
      },
      "direct_transition": "PD_Onset"
    },
    "PD_Onset": {
      "type": "ConditionOnset",
      "target_encounter": "Neurology_Encounter",
      "assign_to_attribute": "parkinsons_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "49049000",
          "display": "Parkinson's disease (disorder)"
        }
      ],
      "direct_transition": "Set_Parkinsons_Attribute"
    },
    "Set_Parkinsons_Attribute": {
      "type": "SetAttribute",
      "attribute": "parkinsons",
      "value": true,
      "remarks": [
        "Boolean flag so other modules can key off this condition."
      ],
      "direct_transition": "Tremor_Symptom"
    },
    "Tremor_Symptom": {
      "type": "Symptom",
      "symptom": "Tremor",
      "cause": "Parkinson's Disease",
      "range": {
        "low": 30,
        "high": 60
      },
      "direct_transition": "Bradykinesia_Symptom"
    },
    "Bradykinesia_Symptom": {
      "type": "Symptom",
      "symptom": "Bradykinesia",
      "cause": "Parkinson's Disease",
      "range": {
        "low": 20,
        "high": 50
      },
      "direct_transition": "Stiffness_Symptom"
    },
    "Stiffness_Symptom": {
      "type": "Symptom",
      "symptom": "Stiffness",
      "cause": "Parkinson's Disease",
      "range": {
        "low": 20,
        "high": 50
      },
      "direct_transition": "Neurology_Encounter"
    },
    "Neurology_Encounter": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "reason": "parkinsons_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "185347001",
          "display": "Encounter for problem (procedure)"
        }
      ],
      "direct_transition": "Neurological_Exam"
    },
    "Neurological_Exam": {
      "type": "Procedure",
      "reason": "parkinsons_condition",
      "remarks": [
