              {
                "condition_type": "Gender",
                "gender": "F"
              },
              {
                "condition_type": "Or",
                "conditions": [
                  {
                    "condition_type": "Attribute",
                    "attribute": "depression",
                    "operator": "==",
                    "value": true
                  },
                  {
                    "condition_type": "Attribute",
                    "attribute": "mdd",
                    "operator": "is not nil"
                  }
                ]
              }
            ]
          },
          "distributions": [
            {
              "transition": "GAD_Onset",
              "distribution": 0.0055
            },
            {
              "transition": "Wait_For_Onset",
              "distribution": 0.9945
            }
          ]
        },
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "F"
          },
          "distributions": [
            {
              "transition": "GAD_Onset",
              "distribution": 0.0022
            },
            {
              "transition": "Wait_For_Onset",
              "distribution": 0.9978
            }
          ]
        },
        {
          "condition": {
            "condition_type": "Or",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "depression",
                "operator": "==",
                "value": true
              },
              {
                "condition_type": "Attribute",
                "attribute": "mdd",
                "operator": "is not nil"
              }
