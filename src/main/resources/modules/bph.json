          "code": "185345009",
          "display": "Encounter for symptom (procedure)"
        }
      ],
      "direct_transition": "Record_PSA"
    },
    "Record_PSA": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [
