      "type": "Initial",
      "distributed_transition": [
        {
          "distribution": 0.18,
          "transition": "Delay_To_Risk_Age"
        },
        {
          "distribution": 0.82,
          "transition": "Terminal"
        }
      ]
    },
    "Terminal": {
      "type": "Terminal"
    },
