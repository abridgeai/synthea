      "direct_transition": "Onset_Check"
    },
    "Onset_Check": {
      "type": "Simple",
      "remarks": [
        "Annual onset hazard, checked from age 12 until age 50 (most first onsets occur teens ",
        "through 40s per Kessler 2005). Veterans exit here because veteran_mdd models their MDD. ",
        "Female 0.006/yr (~20% lifetime), male 0.003/yr (~11% lifetime); chronic comorbidities ",
        "(diabetes, COPD, CHF, opioid addiction) raise the hazard roughly 1.7x."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "veteran",
            "operator": "is not nil"
          },
          "transition": "Terminal"
        },
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">",
            "quantity": 50,
            "unit": "years"
          },
          "transition": "Terminal"
        },
        {
          "condition": {
            "condition_type": "And",
            "conditions": [
              {
                "condition_type": "Gender",
                "gender": "F"
              },
              {
                "condition_type": "Or",
                "conditions": [
                  {
                    "condition_type": "Attribute",
                    "attribute": "diabetes",
                    "operator": "==",
                    "value": true
                  },
                  {
                    "condition_type": "Attribute",
                    "attribute": "copd_variant",
                    "operator": "is not nil"
                  },
                  {
                    "condition_type": "Attribute",
                    "attribute": "chf",
                    "operator": "is not nil"
                  },
                  {
                    "condition_type": "Attribute",
                    "attribute": "opioid_addiction",
                    "operator": "==",
                    "value": true
                  }
                ]
              }
            ]
          },
          "distributions": [
            {
              "transition": "MDD_Onset",
              "distribution": 0.01
            },
            {
              "transition": "Wait_For_Onset",
              "distribution": 0.99
            }
          ]
        },
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "F"
          },
          "distributions": [
            {
              "transition": "MDD_Onset",
              "distribution": 0.006
            },
            {
              "transition": "Wait_For_Onset",
              "distribution": 0.994
            }
          ]
        },
        {
          "condition": {
            "condition_type": "Or",
            "conditions": [
              {
                "condition_type": "Attribute",
                "attribute": "diabetes",
                "operator": "==",
                "value": true
              },
              {
                "condition_type": "Attribute",
                "attribute": "copd_variant",
                "operator": "is not nil"
              },
              {
                "condition_type": "Attribute",
                "attribute": "chf",
                "operator": "is not nil"
              },
              {
                "condition_type": "Attribute",
                "attribute": "opioid_addiction",
                "operator": "==",
                "value": true
              }
            ]
          },
          "distributions": [
            {
              "transition": "MDD_Onset",
              "distribution": 0.005
            },
            {
              "transition": "Wait_For_Onset",
              "distribution": 0.995
            }
          ]
        },
