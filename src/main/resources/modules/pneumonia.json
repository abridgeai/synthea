          "display": "azithromycin 250 MG Oral Tablet [Zithromax]"
        }
      ],
      "direct_transition": "End_Ambulatory_Encounter"
    },
    "Prescribe_Doxycycline": {
      "type": "MedicationOrder",
      "assign_to_attribute": "cap_antibiotic",
      "reason": "cap_pneumonia",
      "codes": [
        {
          "system": "RxNorm",
          "code": "1649987",
          "display": "doxycycline hyclate 100 MG"
        }
      ],
      "direct_transition": "End_Ambulatory_Encounter"
    },
    "End_Ambulatory_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Outpatient_Antibiotic_Course"
    },
    "Outpatient_Antibiotic_Course": {
      "type": "Delay",
      "range": {
        "low": 5,
        "high": 7,
        "unit": "days"
      },
      "direct_transition": "End_Oral_Antibiotic"
    },
    "End_Oral_Antibiotic": {
      "type": "MedicationEnd",
      "referenced_by_attribute": "cap_antibiotic",
      "remarks": [
        "~6% of outpatient-treated CAP fails oral therapy and requires hospital admission."
      ],
      "distributed_transition": [
        {
          "distribution": 0.94,
          "transition": "Pneumonia_Resolves"
        },
        {
          "distribution": 0.06,
          "transition": "Outpatient_Treatment_Failure"
        }
      ]
    },
    "Outpatient_Treatment_Failure": {
      "type": "Simple",
      "direct_transition": "Pneumonia_Inpatient_Encounter"
    },
    "Pneumonia_Dx_ED": {
      "type": "ConditionOnset",
      "target_encounter": "Pneumonia_ED_Encounter",
      "assign_to_attribute": "cap_pneumonia",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "233604007",
          "display": "Pneumonia (disorder)"
        }
      ],
      "direct_transition": "Pneumonia_ED_Encounter"
    },
    "Pneumonia_ED_Encounter": {
      "type": "Encounter",
      "encounter_class": "emergency",
      "reason": "cap_pneumonia",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "50849002",
          "display": "Emergency room admission (procedure)"
        }
      ],
      "direct_transition": "Chest_Xray_ED"
    },
    "Chest_Xray_ED": {
      "type": "Procedure",
      "reason": "cap_pneumonia",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "399208008",
          "display": "Plain X-ray of chest (procedure)"
        }
      ],
      "duration": {
        "low": 10,
        "high": 25,
        "unit": "minutes"
      },
      "direct_transition": "ED_Oxygen_Saturation"
    },
    "ED_Oxygen_Saturation": {
      "type": "Observation",
      "category": "vital-signs",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "2708-6",
          "display": "Oxygen saturation in Arterial blood"
        },
        {
          "system": "LOINC",
          "code": "59408-5",
          "display": "Oxygen saturation in Arterial blood by Pulse oximetry"
        }
      ],
      "range": {
        "low": 84,
        "high": 95
      },
      "direct_transition": "ED_Disposition"
    },
    "ED_Disposition": {
      "type": "Simple",
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">=",
            "quantity": 65,
            "unit": "years"
          },
          "distributions": [
            {
              "distribution": 0.7,
              "transition": "End_ED_Encounter_Admit"
            },
            {
              "distribution": 0.3,
              "transition": "ED_Oral_Antibiotic"
            }
          ]
        },
        {
          "distributions": [
            {
              "distribution": 0.4,
              "transition": "End_ED_Encounter_Admit"
            },
            {
              "distribution": 0.6,
              "transition": "ED_Oral_Antibiotic"
            }
          ]
        }
      ]
    },
    "ED_Oral_Antibiotic": {
      "type": "MedicationOrder",
      "assign_to_attribute": "cap_antibiotic",
      "reason": "cap_pneumonia",
      "codes": [
        {
          "system": "RxNorm",
          "code": "562251",
          "display": "Amoxicillin 250 MG / Clavulanate 125 MG Oral Tablet"
        }
      ],
      "direct_transition": "End_ED_Encounter_Discharge"
    },
    "End_ED_Encounter_Discharge": {
      "type": "EncounterEnd",
      "direct_transition": "Outpatient_Antibiotic_Course"
    },
    "End_ED_Encounter_Admit": {
      "type": "EncounterEnd",
      "direct_transition": "Pneumonia_Inpatient_Encounter"
    },
    "Pneumonia_Inpatient_Encounter": {
      "type": "Encounter",
      "encounter_class": "inpatient",
      "reason": "cap_pneumonia",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "32485007",
          "display": "Hospital admission (procedure)"
        }
      ],
      "direct_transition": "IV_Antibiotic"
    },
    "IV_Antibiotic": {
      "type": "MedicationOrder",
      "reason": "cap_pneumonia",
      "remarks": [
        "IV ceftriaxone represents inpatient parenteral antibiotic therapy for CAP.",
        "RxNorm code reused from uti/abx_tx.json."
      ],
      "codes": [
        {
          "system": "RxNorm",
          "code": "1665021",
          "display": "ceftriaxone 1000 MG Injection"
        }
      ],
      "direct_transition": "Inpatient_Oxygen_Saturation"
    },
    "Inpatient_Oxygen_Saturation": {
      "type": "Observation",
      "category": "vital-signs",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "2708-6",
          "display": "Oxygen saturation in Arterial blood"
        },
        {
          "system": "LOINC",
          "code": "59408-5",
          "display": "Oxygen saturation in Arterial blood by Pulse oximetry"
        }
      ],
      "range": {
        "low": 85,
        "high": 93
      },
      "direct_transition": "Inpatient_Stay"
    },
    "Inpatient_Stay": {
      "type": "Delay",
      "range": {
        "low": 3,
        "high": 7,
        "unit": "days"
      },
      "remarks": [
        "Inpatient CAP mortality: ~8% for patients 65+, ~2% for younger inpatients."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">=",
            "quantity": 65,
            "unit": "years"
