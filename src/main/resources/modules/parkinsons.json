        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "pd_levodopa",
            "operator": "is nil"
          },
          "transition": "Resume_Levodopa"
        },
        {
          "transition": "Early_Adherence_Check"
        }
      ]
    },
    "Resume_Levodopa": {
      "type": "MedicationOrder",
      "assign_to_attribute": "pd_levodopa",
      "reason": "parkinsons_condition",
      "remarks": [
        "Patients who stopped therapy resume it at the next follow-up after symptoms worsen."
