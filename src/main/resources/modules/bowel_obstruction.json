      "value": "Multiple dilated small-bowel loops with air-fluid levels and a paucity of colonic gas, suggestive of small bowel obstruction.",
      "direct_transition": "Xray_Report"
    },
    "Xray_Report": {
      "type": "DiagnosticReport",
      "codes": [
        {
          "system": "LOINC",
          "code": "18748-4",
          "display": "Diagnostic imaging study"
        }
      ],
      "observations": [
        {
          "category": "imaging",
          "codes": [
            {
              "system": "LOINC",
              "code": "18748-4",
              "display": "Diagnostic imaging study"
            }
          ],
          "attribute": "imaging_impression"
        }
      ],
      "direct_transition": "Abdominal_CT"
    },
    "Abdominal_CT": {
      "type": "ImagingStudy",
      "reason": "SBO_Onset",
      "remarks": [
        "CT of the abdomen and pelvis with contrast confirms the obstruction, localizes the ",
        "transition point, and evaluates for ischemia. Generic CT SNOMED code; modality is CT."
      ],
      "procedure_code": {
        "system": "SNOMED-CT",
        "code": "77477000",
        "display": "Computed tomography (procedure)"
      },
      "series": [
        {
          "body_site": {
            "system": "SNOMED-CT",
            "code": "113345001",
            "display": "Abdominal structure (body structure)"
          },
          "modality": {
            "system": "DICOM-DCM",
            "code": "CT",
            "display": "Computed Tomography"
          },
          "instances": [
            {
              "title": "CT of the abdomen and pelvis with contrast",
              "sop_class": {
                "system": "DICOM-SOP",
                "code": "1.2.840.10008.5.1.4.1.1.2",
                "display": "CT Image Storage"
              }
            }
          ]
        }
      ],
      "direct_transition": "Severity_Selection"
    },
    "Severity_Selection": {
      "type": "Simple",
      "remarks": [
        "~70% are partial/low-grade adhesive obstructions managed conservatively; ~30% are ",
        "high-grade or show ischemia and require operative management."
      ],
      "distributed_transition": [
        {
          "distribution": 0.7,
          "transition": "Set_CT_Partial_Impression"
        },
        {
          "distribution": 0.3,
          "transition": "Set_CT_Complete_Impression"
        }
      ]
    },
    "Set_CT_Partial_Impression": {
      "type": "SetAttribute",
      "attribute": "imaging_impression",
      "value": "Dilated small-bowel loops with a transition point in the mid-abdomen and normally enhancing bowel wall, consistent with partial adhesive small bowel obstruction. No pneumatosis or free air.",
      "direct_transition": "CT_Report"
    },
    "Set_CT_Complete_Impression": {
      "type": "SetAttribute",
      "attribute": "imaging_impression",
      "value": "High-grade small bowel obstruction with a discrete transition point, mesenteric edema, and reduced bowel-wall enhancement, concerning for compromised bowel.",
      "direct_transition": "CT_Report"
    },
    "CT_Report": {
      "type": "DiagnosticReport",
      "codes": [
        {
          "system": "LOINC",
          "code": "18748-4",
          "display": "Diagnostic imaging study"
        }
      ],
      "observations": [
        {
          "category": "imaging",
          "codes": [
            {
              "system": "LOINC",
              "code": "18748-4",
              "display": "Diagnostic imaging study"
            }
          ],
          "attribute": "imaging_impression"
        }
      ],
