        }
      ]
    },
    "End_Oral_Antibiotic": {
      "type": "MedicationEnd",
      "referenced_by_attribute": "cellulitis_antibiotic",
      "direct_transition": "Cellulitis_Resolves"
    },
    "Cellulitis_Worsens": {
