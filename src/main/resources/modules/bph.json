{
  "name": "Benign Prostatic Hyperplasia",
  "remarks": [
    "Benign prostatic hyperplasia (BPH) model. Males only, with onset from age 50.",
    "",
    "PREVALENCE: Histologic BPH is present in ~50-60% of men in their 60s and ~70-80% of men ",
    "in their 70s-80s (Berry SJ et al., 'The development of human benign prostatic hyperplasia ",
    "with age', J Urol 1984;132:474-479). This module uses an annual onset hazard of 4% per ",
    "year beginning at age 50, giving cumulative prevalence of ~34% by age 60, ~56% by age 70, ",
    "and ~71% by age 80, approximating clinically apparent disease.",
    "",
    "FLOW: Lower urinary tract symptoms (urinary frequency, nocturia) lead to an ambulatory ",
    "encounter where BPH is diagnosed, a PSA is drawn (BPH commonly elevates PSA), and an ",
    "alpha-blocker (tamsulosin 0.4 MG daily) is started. Patients are followed annually with ",
    "repeat PSA. Each year, ~4% of treated patients progress (worsening symptoms) and are ",
    "referred to urology, where finasteride (5-alpha-reductase inhibitor) is added per AUA ",
    "guidelines for combination therapy. Of patients under urology care, ~10% per year go on ",
    "to transurethral resection of the prostate (TURP), performed as an inpatient surgical ",
    "admission; medications are stopped after TURP and urinary symptoms largely resolve.",
    "",
    "NON-ADHERENCE: At each annual follow-up, 13% of patients on tamsulosin discontinue it; ",
    "patients off therapy have a 55% chance of restarting at each subsequent follow-up ",
    "(persistence with BPH pharmacotherapy at 1 year is commonly reported below 70%; ",
    "Cindolo et al., Eur Urol 2015;68:418-425).",
    "",
    "ATTRIBUTES: sets 'bph' = true at onset (for cross-module correlation), 'bph_condition' ",
    "(the condition itself), 'bph_alpha_blocker' (active tamsulosin), 'bph_5ari' (active ",
    "finasteride), and 'bph_med_stopped' (non-adherence flag).",
    "",
    "CODES: PSA LOINC 2857-1 is reused from veteran_prostate_cancer.json. BPH SNOMED 266569009, ",
    "TURP SNOMED 90199006 (Transurethral prostatectomy), tamsulosin RxNorm 863669, and ",
    "finasteride RxNorm 310346 were verified against SNOMED CT (tx.fhir.org, Feb 2025 release) ",
    "and RxNav."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Gender",
            "gender": "M"
          },
          "transition": "Age_Guard"
        },
        {
          "transition": "Terminal"
        }
      ]
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Annual_Onset_Check"
    },
    "Annual_Onset_Check": {
      "type": "Delay",
      "exact": {
        "quantity": 1,
        "unit": "years"
      },
      "remarks": [
        "4% annual onset hazard from age 50: cumulative ~34% by 60, ~56% by 70, ~71% by 80 ",
        "(Berry et al., J Urol 1984). Men who reach age 90 without BPH exit the module."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">=",
            "quantity": 90,
            "unit": "years"
          },
          "transition": "Terminal"
        },
        {
          "distributions": [
            {
              "distribution": 0.04,
              "transition": "Urinary_Frequency_Symptom"
            },
            {
              "distribution": 0.96,
              "transition": "Annual_Onset_Check"
            }
          ]
        }
      ]
    },
    "Urinary_Frequency_Symptom": {
      "type": "Symptom",
      "symptom": "Urinary Frequency",
      "cause": "Benign Prostatic Hyperplasia",
      "range": {
        "low": 30,
        "high": 70
      },
      "direct_transition": "Nocturia_Symptom"
    },
    "Nocturia_Symptom": {
