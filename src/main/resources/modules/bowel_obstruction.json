      ],
      "procedure_code": {
        "system": "SNOMED-CT",
        "code": "168537006",
        "display": "Plain radiography (procedure)"
      },
      "series": [
        {
          "body_site": {
            "system": "SNOMED-CT",
            "code": "113345001",
            "display": "Abdominal structure (body structure)"
          },
          "modality": {
            "system": "DICOM-DCM",
            "code": "DX",
            "display": "Digital Radiography"
          },
          "instances": [
