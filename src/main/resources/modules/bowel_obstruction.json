{
  "name": "Bowel Obstruction",
  "remarks": [
    "This module models acute mechanical SMALL BOWEL OBSTRUCTION (SBO), the most common ",
    "surgical small-bowel emergency. The dominant etiologies are post-operative adhesions and ",
    "hernias. It exists to add a high-acuity abdominal presentation and its standard imaging ",
    "workup to the synthetic population: an abdominal radiograph (obstructive series) followed ",
    "by CT of the abdomen and pelvis, which is the modern test of choice for confirming the ",
    "obstruction, locating the transition point, and detecting ischemia. Both studies are ",
    "modeled as ImagingStudy states with a DiagnosticReport carrying a free-text impression, so ",
    "they export as FHIR ImagingStudy + DiagnosticReport resources and surface in the LLM note ",
    "context. Management follows the CT read: most partial/adhesive obstructions resolve with ",
    "nasogastric decompression and IV fluids (bowel rest), while high-grade obstruction or ",
    "suspected ischemia goes to laparotomy with lysis of adhesions. Adhesive SBO recurs, which ",
    "the module captures with a recurrence loop.",
    "Epidemiology: adhesions account for ~60-70% of SBO; SBO causes roughly 300,000 ",
    "hospitalizations per year in the US. This model gives 12% of people lifetime susceptibility ",
    "with a ~1.2% annual episode probability from mid-adulthood to age 85.",
    "Sources: ",
    "Miller G, et al. 'Etiology of small bowel obstruction.' Am J Surg. 2000;180(1):33-36. ",
    "Maung AA, et al. 'Evaluation and management of small-bowel obstruction: EAST practice ",
    "management guideline.' J Trauma Acute Care Surg. 2012;73(5 Suppl 4):S362-S369.",
    "Codes for the abdominal body site, IV fluids, and the nasogastric tube device are reused ",
    "from existing modules; generic radiography/CT/surgical SNOMED codes carry modality-specific ",
    "detail in the instance titles."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "remarks": [
        "12% of people experience at least one mechanical bowel obstruction in their lifetime."
      ],
      "distributed_transition": [
        {
          "distribution": 0.12,
          "transition": "Delay_Until_Risk"
        },
        {
          "distribution": 0.88,
          "transition": "Terminal"
        }
      ]
    },
    "Delay_Until_Risk": {
      "type": "Delay",
      "remarks": [
        "Risk is concentrated in mid-adulthood and later, reflecting the accrual of prior ",
        "abdominal surgery and hernias."
      ],
      "range": {
        "low": 40,
        "high": 55,
        "unit": "years"
      },
      "direct_transition": "Annual_Risk"
    },
    "Annual_Risk": {
      "type": "Delay",
      "exact": {
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Annual_Risk_Check"
    },
    "Annual_Risk_Check": {
      "type": "Simple",
      "remarks": [
        "~1.2% annual episode probability through age 85."
      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">",
            "quantity": 85,
            "unit": "years"
          },
          "transition": "Terminal"
        },
        {
          "distributions": [
            {
              "distribution": 0.012,
              "transition": "SBO_Onset"
            },
            {
              "distribution": 0.988,
              "transition": "Annual_Risk"
            }
          ]
        }
      ]
    },
    "SBO_Onset": {
      "type": "ConditionOnset",
      "target_encounter": "SBO_Encounter",
      "assign_to_attribute": "bowel_obstruction_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "81060008",
          "display": "Intestinal obstruction (disorder)"
        }
      ],
      "direct_transition": "Pain_Symptom"
    },
    "Pain_Symptom": {
      "type": "Symptom",
      "symptom": "Abdominal Pain",
      "cause": "Bowel Obstruction",
      "range": {
        "low": 50,
        "high": 90
      },
      "direct_transition": "Distension_Symptom"
    },
    "Distension_Symptom": {
      "type": "Symptom",
      "symptom": "Abdominal Distension",
      "cause": "Bowel Obstruction",
      "range": {
        "low": 40,
        "high": 80
      },
      "direct_transition": "Vomiting_Symptom"
    },
    "Vomiting_Symptom": {
      "type": "Symptom",
      "symptom": "Nausea/Vomiting",
      "cause": "Bowel Obstruction",
      "range": {
        "low": 40,
        "high": 90
      },
      "direct_transition": "Obstipation_Symptom"
    },
    "Obstipation_Symptom": {
      "type": "Symptom",
      "symptom": "Constipation",
      "cause": "Bowel Obstruction",
      "range": {
        "low": 40,
        "high": 90
      },
      "direct_transition": "SBO_Encounter"
    },
    "SBO_Encounter": {
      "type": "Encounter",
      "encounter_class": "emergency",
      "reason": "SBO_Onset",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "50849002",
          "display": "Emergency room admission (procedure)"
        }
      ],
      "direct_transition": "SBO_Pain_Observation"
    },
    "SBO_Pain_Observation": {
