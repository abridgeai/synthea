{
  "name": "Acute Pancreatitis",
  "remarks": [
    "Acute pancreatitis affects well under 1% of the population per year in the general population.",
    "Gallstones and alcohol use are the two leading etiologies, together accounting for the large majority of cases, with a smaller share attributable to other causes (hypertriglyceridemia, medications, idiopathic, etc.).",
    "Roughly 15-20% of cases are severe/necrotizing, and severe disease carries meaningful mortality risk during the index admission.",
    "Sources: Tenner S, et al. American College of Gastroenterology Guideline: Management of Acute Pancreatitis. Am J Gastroenterol. 2013. Peery AF, et al. Burden of Gastrointestinal Disease in the United States. Gastroenterology. 2012."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "distributed_transition": [
        {
          "distribution": 0.10,
          "transition": "Delay_To_Adulthood"
        },
        {
          "distribution": 0.90,
          "transition": "Terminal"
        }
      ]
    },
    "Terminal": {
      "type": "Terminal"
    },
    "Delay_To_Adulthood": {
      "type": "Delay",
      "range": {
        "low": 25,
        "high": 50,
        "unit": "years"
      },
      "direct_transition": "Hazard_Age_Check"
    },
    "Hazard_Age_Check": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">",
            "quantity": 90,
            "unit": "years"
          },
          "transition": "Terminal"
        },
        {
          "transition": "Hazard_Roll"
        }
      ]
    },
    "Hazard_Roll": {
      "type": "Simple",
      "distributed_transition": [
        {
          "distribution": 0.008,
          "transition": "Determine_Etiology"
        },
        {
          "distribution": 0.992,
          "transition": "Hazard_Wait"
        }
      ]
    },
    "Hazard_Wait": {
      "type": "Delay",
      "exact": {
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Hazard_Age_Check"
    },
    "Determine_Etiology": {
      "type": "Simple",
      "distributed_transition": [
        {
          "distribution": 0.45,
          "transition": "Etiology_Gallstone"
        },
        {
          "distribution": 0.35,
          "transition": "Etiology_Alcohol"
        },
        {
          "distribution": 0.20,
          "transition": "Etiology_Other"
        }
      ]
    },
    "Etiology_Gallstone": {
      "type": "SetAttribute",
      "attribute": "pancreatitis_etiology",
      "value": "gallstone",
      "direct_transition": "Onset_Symptoms"
    },
    "Etiology_Alcohol": {
      "type": "SetAttribute",
      "attribute": "pancreatitis_etiology",
      "value": "alcohol",
      "direct_transition": "Onset_Symptoms"
    },
    "Etiology_Other": {
      "type": "SetAttribute",
      "attribute": "pancreatitis_etiology",
      "value": "other",
      "direct_transition": "Onset_Symptoms"
    },
    "Onset_Symptoms": {
      "type": "Symptom",
      "symptom": "Abdominal Pain",
      "cause": "Acute Pancreatitis",
      "range": {
        "low": 60,
        "high": 95
      },
      "direct_transition": "Symptom_Nausea"
    },
    "Symptom_Nausea": {
      "type": "Symptom",
      "symptom": "Nausea/Vomiting",
      "cause": "Acute Pancreatitis",
      "range": {
        "low": 40,
        "high": 90
      },
      "direct_transition": "ED_Encounter"
    },
    "ED_Encounter": {
      "type": "Encounter",
      "encounter_class": "emergency",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "50849002",
          "display": "Emergency room admission (procedure)"
        }
      ],
      "direct_transition": "Onset_Condition"
    },
    "Onset_Condition": {
      "type": "ConditionOnset",
      "target_encounter": "ED_Encounter",
      "assign_to_attribute": "pancreatitis_condition",
