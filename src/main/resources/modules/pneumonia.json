      "direct_transition": "End_Encounter_By_Death"
    },
    "End_Encounter_By_Death": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal"
    },
    "Terminal": {
      "type": "Terminal"
    }
  },
  "gmf_version": 2
}
