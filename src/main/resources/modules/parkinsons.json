          "system": "SNOMED-CT",
          "code": "185347001",
          "display": "Encounter for problem (procedure)"
        }
      ],
      "direct_transition": "Early_Followup_Exam"
    },
    "Early_Followup_Exam": {
      "type": "Procedure",
      "reason": "parkinsons_condition",
