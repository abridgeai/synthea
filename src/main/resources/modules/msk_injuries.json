{
  "name": "Musculoskeletal Injuries",
  "remarks": [
    "This module models recurring ACUTE musculoskeletal (MSK) and minor traumatic injuries ",
    "across the lifetime: ankle sprains, distal-forearm/wrist fractures, internal knee ",
    "derangement (meniscal tear), and concussion. It exists to add diagnostic-imaging volume ",
    "to the synthetic population, because acute MSK trauma is one of the most imaging-intensive ",
    "reasons for ambulatory and emergency care. Each injury drives the imaging that is standard ",
    "of care: plain radiographs for suspected fracture/sprain, MRI for internal knee derangement, ",
    "and a non-contrast head CT for concussion. Every imaging event is modeled as an ImagingStudy ",
    "state (not a bare Procedure) so it exports as a FHIR ImagingStudy resource with DICOM ",
    "modality/body-site metadata and surfaces in the LLM note context's imaging section.",
    "Epidemiology: acute MSK injuries are extremely common; ankle sprains alone account for ~2 ",
    "per 1000 person-years, and distal-radius fractures are the most common fracture in adults. ",
    "This model gives 85% of people susceptibility with a ~3% annual injury probability from ",
    "adolescence to age 85, and faster recurrence after a first injury. Codes for conditions, ",
    "radiographs, immobilization, and care plans are reused from injuries.json.",
    "Sources: ",
    "Waterman BR, et al. 'The epidemiology of ankle sprains in the United States.' J Bone Joint ",
    "Surg Am. 2010;92(13):2279-2284. ",
    "Nellans KW, Kowalski E, Chung KC. 'The epidemiology of distal radius fractures.' Hand Clin. ",
    "2012;28(2):113-125."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "remarks": [
        "85% of people sustain at least one acute MSK/traumatic injury during their lifetime."
      ],
      "distributed_transition": [
        {
          "distribution": 0.85,
          "transition": "Delay_Until_Active"
        },
        {
          "distribution": 0.15,
          "transition": "Terminal"
        }
      ]
    },
    "Delay_Until_Active": {
      "type": "Delay",
      "remarks": [
        "Risk begins in adolescence once children are physically active in sports/recreation."
      ],
      "range": {
        "low": 12,
        "high": 18,
        "unit": "years"
      },
      "direct_transition": "Annual_Risk"
    },
    "Annual_Risk": {
      "type": "Delay",
      "exact": {
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Annual_Risk_Check"
    },
    "Annual_Risk_Check": {
      "type": "Simple",
      "remarks": [
