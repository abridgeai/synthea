          "code": "72514-3",
          "display": "Pain severity - 0-10 verbal numeric rating [Score] - Reported"
        }
      ],
      "range": {
        "decimals": 0,
        "low": 5,
        "high": 9
      },
      "direct_transition": "Abdominal_Xray"
    },
    "Abdominal_Xray": {
      "type": "ImagingStudy",
      "reason": "SBO_Onset",
      "remarks": [
