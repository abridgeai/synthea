      ],
      "complex_transition": [
        {
          "condition": {
            "condition_type": "Age",
            "operator": ">",
            "quantity": 85,
            "unit": "years"
          },
          "transition": "Terminal"
        },
        {
          "distributions": [
            {
              "distribution": 0.03,
              "transition": "Injury_Selection"
            },
            {
              "distribution": 0.97,
              "transition": "Annual_Risk"
            }
          ]
        }
      ]
    },
