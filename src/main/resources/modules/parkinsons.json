    },
    "End_Neurology_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Early_PD_Period"
    },
    "Early_PD_Period": {
      "type": "Delay",
      "exact": {
        "quantity": 6,
        "unit": "months"
      },
      "direct_transition": "Early_Followup_Encounter"
    },
    "Early_Followup_Encounter": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "reason": "parkinsons_condition",
      "codes": [
