        "high": 2,
        "unit": "weeks"
      },
      "direct_transition": "Pneumonia_Resolves"
    },
    "Pneumonia_Resolves": {
      "type": "ConditionEnd",
      "referenced_by_attribute": "cap_pneumonia",
      "direct_transition": "Cough_Subsides"
    },
    "Cough_Subsides": {
      "type": "Symptom",
      "symptom": "Cough",
      "exact": {
        "quantity": 0
