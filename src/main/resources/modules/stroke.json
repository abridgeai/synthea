        }
      ],
      "observations": [
        {
          "category": "imaging",
          "codes": [
            {
              "system": "LOINC",
              "code": "18748-4",
              "display": "Diagnostic imaging study"
            }
          ],
          "attribute": "imaging_impression"
        }
      ],
      "direct_transition": "Brain_MRI"
